{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "seophp/schema-org",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "seophp",
        "seo",
        "schema-org"
    ],
    "homepage": "https://github.com/seophp/seo",
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Seo\\SchemaOrg\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seo\\SchemaOrg\\Tests\\": "tests",
            "Seo\\SchemaOrg\\Generator\\": "generator/src"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
