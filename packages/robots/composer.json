{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "seophp/robots",
    "description": "Lightweight, framework-agnostic robots.txt management for PHP",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "seophp",
        "seo",
        "robots"
    ],
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Seo\\Robots\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seo\\Robots\\Tests\\": "tests"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
