{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "seophp/llms-txt",
    "description": "Lightweight, framework-agnostic llms.txt management for PHP",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "seophp",
        "seo",
        "llms",
        "llms.txt"
    ],
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Seo\\LlmsTxt\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seo\\LlmsTxt\\Tests\\": "tests"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
