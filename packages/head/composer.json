{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "seophp/head",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "seophp",
        "seo",
        "head"
    ],
    "homepage": "https://github.com/seo-php/seo",
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Seo\\Head\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seo\\Head\\Tests\\": "tests"
        }
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
